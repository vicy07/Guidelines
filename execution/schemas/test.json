{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "requirement_id", "task_ids", "summary", "checks", "verdict"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TEST-[0-9]{4}$"
    },
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$"
    },
    "task_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^TASK-[0-9]{4}$"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    }
  }
}
