{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "requirement_id", "test_report_id", "version", "status", "notes"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REL-[0-9]{4}$"
    },
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$"
    },
    "test_report_id": {
      "type": "string",
      "pattern": "^TEST-[0-9]{4}$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "released", "rolled_back"]
    },
    "released_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string",
      "minLength": 5
    }
  }
}
