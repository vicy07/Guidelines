{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["chain_id", "artifacts", "lineage"],
  "properties": {
    "chain_id": {
      "type": "string",
      "minLength": 3
    },
    "artifacts": {
      "type": "object",
      "required": ["raw_request", "requirement", "tasks", "test_report", "release"],
      "properties": {
        "raw_request": {"type": "string"},
        "requirement": {"type": "string"},
        "tasks": {"type": "string"},
        "test_report": {"type": "string"},
        "release": {"type": "string"}
      }
    },
    "lineage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "step"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "step": {"type": "string"}
        }
      }
    }
  }
}
