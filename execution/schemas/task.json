{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["requirement_id", "tasks"],
  "properties": {
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "requirement_id", "title", "type", "estimate_points", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{4}$"
          },
          "requirement_id": {
            "type": "string",
            "pattern": "^REQ-[0-9]{4}$"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 160
          },
          "type": {
            "type": "string",
            "enum": ["feature", "bugfix", "refactor", "ops", "test"]
          },
          "estimate_points": {
            "type": "integer",
            "minimum": 1,
            "maximum": 21
          },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "done"]
          }
        }
      }
    }
  }
}
